# Database
# DATABASE_PROVIDER supports sqlite (default) or postgresql.
DATABASE_PROVIDER="sqlite"
DATABASE_URL="file:./prisma/dev.db"
# PostgreSQL example:
# DATABASE_PROVIDER="postgresql"
# DATABASE_URL="postgresql://feedferret:feedferret-change-me@localhost:5432/feedferret?schema=public"

# Auth (required)
NEXTAUTH_SECRET="your-super-secret-key-change-this"
NEXTAUTH_URL="http://localhost:3000"

# Internal API key for SaaS provisioning (required if using /api/internal/* routes)
# Generate with: openssl rand -base64 32
# INTERNAL_API_KEY=""

# Optional authenticator-app label for local 2FA
# TOTP_ISSUER="FeedFerret"

# Optional: Enable Google OAuth
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# Optional: Enable GitHub OAuth
# GITHUB_CLIENT_ID=""
# GITHUB_CLIENT_SECRET=""

# Optional: Enable Authelia OIDC login
# AUTHELIA_CLIENT_ID="feedferret"
# AUTHELIA_CLIENT_SECRET="change-me"
# AUTHELIA_ISSUER="https://auth.example.com"
# AUTHELIA_PROVIDER_NAME="Authelia"

# Optional: RSS sync protection secret
# SYNC_SECRET=""

# ─── Email providers ──────────────────────────────────────────────────────────
# Mail provider credentials can be configured here (ENV) OR in the Admin UI
# (stored encrypted in the database). DB values take priority over ENV values.
#
# If you configure credentials in the Admin UI during onboarding or in
# Server Management → Email, you do NOT need to set these ENV variables.

# Resend
# RESEND_API_KEY=""
# RESEND_FROM_EMAIL="FeedFerret <noreply@example.com>"

# Postmark
# POSTMARK_SERVER_TOKEN=""
# POSTMARK_FROM_EMAIL="noreply@example.com"
# POSTMARK_MESSAGE_STREAM="outbound"

# Mailgun
# MAILGUN_API_KEY=""
# MAILGUN_DOMAIN="mg.example.com"
# MAILGUN_FROM_EMAIL="FeedFerret <noreply@example.com>"
# MAILGUN_BASE_URL="https://api.mailgun.net"

# SendGrid
# SENDGRID_API_KEY=""
# SENDGRID_FROM_EMAIL="noreply@example.com"

# ─── Browser Push Notifications ───────────────────────────────────────────────
# Generate with: pnpm run webpush:keys
# Public key is sent to browsers; private key must remain secret.
# WEB_PUSH_VAPID_PUBLIC_KEY=""
# WEB_PUSH_VAPID_PRIVATE_KEY=""
# WEB_PUSH_CONTACT="mailto:admin@example.com"
