# Database
DATABASE_URL="file:./prisma/dev.db"

# Auth
NEXTAUTH_SECRET="your-super-secret-key-change-this"
NEXTAUTH_URL="http://localhost:3000"

# Optional authenticator-app label for local 2FA
# TOTP_ISSUER="FeedFerret"

# Optional: Enable Google OAuth
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# Optional: Enable GitHub OAuth
# GITHUB_CLIENT_ID=""
# GITHUB_CLIENT_SECRET=""

# Optional: Enable Authelia OIDC login
# AUTHELIA_CLIENT_ID="feedferret"
# AUTHELIA_CLIENT_SECRET="change-me"
# AUTHELIA_ISSUER="https://auth.example.com"
# AUTHELIA_PROVIDER_NAME="Authelia"

# Optional API-based email providers.
# Configure one or more, then select the provider in Server Settings.

# Resend
# RESEND_API_KEY=""
# RESEND_FROM_EMAIL="FeedFerret <noreply@example.com>"

# Postmark
# POSTMARK_SERVER_TOKEN=""
# POSTMARK_FROM_EMAIL="noreply@example.com"
# POSTMARK_MESSAGE_STREAM="outbound"

# Mailgun
# MAILGUN_API_KEY=""
# MAILGUN_DOMAIN="mg.example.com"
# MAILGUN_FROM_EMAIL="FeedFerret <noreply@example.com>"
# MAILGUN_BASE_URL="https://api.mailgun.net"

# SendGrid
# SENDGRID_API_KEY=""
# SENDGRID_FROM_EMAIL="noreply@example.com"

# RSS Sync - optional secret to protect /api/sync endpoint
# Generate with: openssl rand -base64 32
# SYNC_SECRET=""
