# ─── Required ─────────────────────────────────────────────────────────────────
# These variables must be set before starting FeedFerret.

# Database provider: "postgresql" (default) or "sqlite"
DATABASE_PROVIDER="postgresql"
DATABASE_URL="postgresql://feedferret:feedferret-change-me@postgres:5432/feedferret?schema=public"

# PostgreSQL credentials (must match DATABASE_URL above)
POSTGRES_DB="feedferret"
POSTGRES_USER="feedferret"
POSTGRES_PASSWORD="feedferret-change-me"   # ← change this!

# Auth secret — signs JWTs and encrypts stored credentials.
# Generate with: openssl rand -base64 32
# WARNING: changing this after first run invalidates all sessions and stored secrets.
AUTH_SECRET="your-super-secret-key-change-this"   # ← change this!

# Public URL of your FeedFerret instance (no trailing slash).
# Used for magic-link emails, OAuth callbacks, and open-graph URLs.
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST=true

# ─── SQLite alternative ───────────────────────────────────────────────────────
# No separate database service needed. Use this instead of the PostgreSQL block.
# DATABASE_PROVIDER="sqlite"
# DATABASE_URL="file:/app/data/dev.db"

# ─── Optional: OAuth providers ────────────────────────────────────────────────
# Enable Google login
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# Enable GitHub login
# GITHUB_CLIENT_ID=""
# GITHUB_CLIENT_SECRET=""

# Enable Authelia / generic OIDC login
# AUTHELIA_CLIENT_ID="feedferret"
# AUTHELIA_CLIENT_SECRET="change-me"
# AUTHELIA_ISSUER="https://auth.example.com"
# AUTHELIA_PROVIDER_NAME="Authelia"

# ─── Optional: Misc ──────────────────────────────────────────────────────────
# Label shown in authenticator apps for TOTP 2FA codes
# TOTP_ISSUER="FeedFerret"

# Secret for the internal SaaS provisioning API (/api/internal/*).
# Only required if you use multi-tenant provisioning.
# Generate with: openssl rand -base64 32
# INTERNAL_API_KEY=""

# Restrict background feed syncs to requests that include this header value.
# Useful when triggering syncs from an external cron job.
# SYNC_SECRET=""

# When converting a web page to a feed (page→feed builder, AI config, full-text
# extraction), FeedFerret uses a browser-fingerprint HTTP client (impit) so more
# sites accept the request. Routine feed (RSS/Atom) syncing is NOT affected.
# Set to 1 to disable it and use plain fetch everywhere (e.g. if a site behaves
# worse with impersonation, or on a platform without the native binary).
# FEEDFERRET_DISABLE_IMPIT=""

# ─── Email providers ──────────────────────────────────────────────────────────
# Configure mail in the Admin UI (Server Management → Email) instead of here —
# credentials entered there are stored encrypted in the database.
# These ENV variables are a fallback for immutable/container deployments.

# Resend
# RESEND_API_KEY=""
# RESEND_FROM_EMAIL="FeedFerret <noreply@example.com>"

# Postmark
# POSTMARK_SERVER_TOKEN=""
# POSTMARK_FROM_EMAIL="noreply@example.com"
# POSTMARK_MESSAGE_STREAM="outbound"

# Mailgun
# MAILGUN_API_KEY=""
# MAILGUN_DOMAIN="mg.example.com"
# MAILGUN_FROM_EMAIL="FeedFerret <noreply@example.com>"
# MAILGUN_BASE_URL="https://api.mailgun.net"

# SendGrid
# SENDGRID_API_KEY=""
# SENDGRID_FROM_EMAIL="noreply@example.com"

# SMTP (any SMTP server)
# SMTP_HOST=""
# SMTP_PORT="587"
# SMTP_USER=""
# SMTP_PASSWORD=""
# SMTP_FROM="FeedFerret <noreply@example.com>"

# ─── Browser Push Notifications ───────────────────────────────────────────────
# Generate keys with: pnpm run webpush:keys
# The public key is sent to browsers; keep the private key secret.
# WEB_PUSH_VAPID_PUBLIC_KEY=""
# WEB_PUSH_VAPID_PRIVATE_KEY=""
# WEB_PUSH_CONTACT="mailto:admin@example.com"

# ─── Error Tracking ──────────────────────────────────────────────────────────
# Optional: Sentry DSN for error monitoring. When set, logger.error() calls
# are forwarded to Sentry in production. See docs/releases/maintenance.md.
# SENTRY_DSN=""
# SENTRY_AUTH_TOKEN=""   # for source-map upload in GitHub Actions

# ─── Feed Fetch Security (SSRF) ───────────────────────────────────────────────
# By default, private/internal IP ranges are blocked to prevent SSRF attacks.
# Enable only on trusted single-tenant instances where you manage all users.
# Prefer toggling this in the Admin UI (Server Management → Sync) instead.
# TRUSTED_FEED_FETCHING="false"
# ALLOW_INTERNAL_FEED_URLS="false"
