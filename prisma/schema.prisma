generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  twoFactorEnabled Boolean @default(false)
  twoFactorSecret  String?
  sessionVersion   Int     @default(0)
  accounts      Account[]
  sessions      Session[]
  loginAttempts LoginAttempt[]
  adminAuditLogs AdminAuditLog[] @relation("AuditActor")
  categories    Category[]
  feeds         Feed[]
  articles      Article[]
  labels        Label[]
  savedSearches SavedSearch[]
  autoReadRules AutoReadRule[]
  keywordAlerts KeywordAlert[]
  notifications Notification[]
  gReaderPreferences GReaderPreference[]
  pushSubscriptions PushSubscription[]
  defaultUpdateFrequency Int @default(60)
  defaultRetentionDays Int @default(90)
  openOriginalByDefault Boolean @default(false)
  markReadAfterDelaySecs Int?      // null=instant(1s), 0=disabled
  defaultViewMode        String    @default("list")   // "list"|"grid"|"magazine"|"minimal"
  readerWidth            String    @default("normal")  // "normal"|"wide"|"full"
  readerFontSize         String    @default("medium")   // "small"|"medium"|"large"|"xl"
  defaultArticleSort     String    @default("newest")  // "newest"|"oldest"
  accentColor            String    @default("#5BA4CF")  // ice blue
  secondaryColor         String    @default("#F0963C")  // soft orange
  apiTokens     ApiToken[]
  isActive      Boolean   @default(true)
  digestEnabled           Boolean   @default(false)
  digestFrequency         String    @default("daily")   // "daily" | "weekly" | "weekdays"
  digestDayOfWeek         Int?                          // 0=Sun … 6=Sat, weekly only
  digestHour              Int       @default(8)         // hour 0-23, interpreted in digestTimezone
  digestTimezone          String    @default("UTC")     // IANA timezone, e.g. "Europe/Berlin"
  digestScope             String    @default("unread")  // "unread" | "starred" | "readlater" | "all"
  digestFeedIds           String?                       // JSON array of feed IDs, null = all
  digestMaxArticles       Int       @default(20)        // upper limit of articles per digest
  digestMinArticles       Int       @default(1)         // skip send if fewer than this
  digestLookbackHours     Int?                          // null = since last sent; else fixed window in hours
  digestGroupByFeed       Boolean   @default(false)     // group articles by feed in the email
  digestAiSummary         String    @default("none")    // "none" | "per_feed" | "full"
  digestSkipFeatured      Boolean   @default(false)     // skip articles already sent in a previous digest
  digestLabelIds          String?                       // JSON array of label IDs, null = no label filter
  digestPausedUntil       DateTime?                     // pause digest until this date
  digestLastSentAt        DateTime?
  digestUnsubscribeToken  String?   @unique
  pushEnabled             Boolean   @default(false)
  pushFrequency           String    @default("immediate") // "off" | "immediate" | "hourly" | "daily"
  pushFeedIds             String?                       // JSON array of feed IDs, null = all
  pushPrivatePayloads     Boolean   @default(true)      // include article titles in push payloads
  pushLastSentAt          DateTime?
  telegramEnabled         Boolean   @default(false)
  telegramBotToken        String?
  telegramChatId          String?
  gotifyEnabled           Boolean   @default(false)
  gotifyUrl               String?
  gotifyToken             String?
  ntfyEnabled             Boolean   @default(false)
  ntfyUrl                 String?
  ntfyToken               String?
  hideDuplicates          Boolean   @default(true)
  markReadOnScroll        Boolean   @default(false)
  layoutDirection         String    @default("ltr")     // "ltr" | "rtl"
  hideEmptyFeeds          Boolean   @default(false)
  hideEmptyLabels         Boolean   @default(false)
  uiLanguage              String    @default("en")     // BCP-47 tag e.g. "en" | "de"
  // Display timezone for every timestamp shown in the app (article dates,
  // reader, etc. — distinct from digestTimezone, which only affects when the
  // email digest is sent). null = auto-detect from the browser (see
  // i18n/request.ts + the `timezone` cookie); an explicit IANA name here
  // always wins.
  displayTimezone         String?
  aiProvider              String?                       // "openai" | "anthropic" | "ollama" | "gemini" | "openrouter"
  aiApiKey                String?                       // encrypted at rest
  aiModel                 String?
  aiOllamaBaseUrl         String?
  aiAutoSummarize         Boolean   @default(false)
  aiSummaryLanguage       String    @default("same")   // "same" | BCP-47 tag e.g. "de"
  aiAutoTag               Boolean   @default(false)     // F8: auto-tag new articles via Label/ArticleLabel on sync
  // BYOK hosted-fetch connector (M7-T3): per-user, opt-in, own API key.
  // The last-resort tier for pages that beat even the browser-render sidecar
  // (M7-T2) — an active anti-bot challenge. Unlike every earlier tier, the
  // target page's content is sent to a third party (labelled accordingly in
  // the UI), so it never runs during background sync unless the user
  // explicitly opts in via contentFetchAutoUse.
  contentFetchProvider    String?                       // "jina" | "firecrawl"
  contentFetchApiKey      String?                       // encrypted at rest
  contentFetchAutoUse     Boolean   @default(false)
  // F6: auto-mute a feed after this many *consecutive* sync failures (see
  // Feed.consecutiveFailureCount / Feed.autoMuted below). 0 = disabled/opt-out.
  autoMuteFailingFeedsAfter Int     @default(10)
  // F5: export destinations ("send to") from the article reader. Obsidian has
  // no API — it's a local vault app — so all it needs is a vault name to build
  // an `obsidian://new` deep link; no credentials involved. Wallabag is a
  // self-hosted read-later service (OAuth2 password grant).
  exportObsidianVault        String?
  exportWallabagUrl          String?
  exportWallabagClientId     String?
  exportWallabagClientSecret String?                    // encrypted at rest
  exportWallabagUsername     String?
  exportWallabagPassword     String?                    // encrypted at rest
  role          String    @default("USER")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([digestEnabled])
  @@index([pushEnabled])
}

model PushSubscription {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint    String    @unique
  p256dh      String
  auth        String
  userAgent   String?
  platform    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lastUsedAt  DateTime?
  disabledAt  DateTime?
  @@index([userId, disabledAt])
}

model AutoReadRule {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String
  query           String
  action          String   // legacy single-action: "mark_read" | "star" | "label:<labelId>"
  // New multi-action list (JSON array of action ids). When present, takes
  // precedence over `action`. Example: ["mark_read","label:abc","notify_inapp"]
  actions         String?
  // Optional scope: "all" | "feed:<id>" | "category:<id>"
  scope           String?
  // What fires this rule: "article" (default — query matches new/existing articles)
  // or "feed_error" (a feed sync fails). Feed-error rules limit actions to
  // notifications and webhooks.
  trigger         String   @default("article")
  // Inline webhook configurations referenced from actions list as
  // "webhook_call:<index>". JSON array of WebhookConfig records.
  webhookConfigs  String?
  enabled         Boolean  @default(true)
  order           Int      @default(0)
  lastTriggeredAt DateTime?
  // When true, deleting this rule clears the spoiler flag from all articles it flagged.
  removeSpoilerOnDelete Boolean @default(false)
  notifications   Notification[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  @@index([userId, enabled, order])
  @@index([userId, trigger, enabled])
}

model KeywordAlert {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String
  query           String
  scope           String   @default("all") // "all" | "feed:<id>" | "category:<id>"
  actions         String   @default("[\"notify_inapp\"]") // JSON array
  enabled         Boolean  @default(true)
  lastTriggeredAt DateTime?
  notifications   Notification[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId, enabled])
  @@index([userId, scope])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // "keyword_alert" | "rule_match" | "feed_error" | "digest_sent" | "feed_auto_muted"
  title     String
  body      String
  articleId String?
  article   Article? @relation(fields: [articleId], references: [id], onDelete: SetNull)
  feedId    String?
  alertId   String?
  alert     KeywordAlert? @relation(fields: [alertId], references: [id], onDelete: SetNull)
  ruleId    String?
  rule      AutoReadRule? @relation(fields: [ruleId], references: [id], onDelete: SetNull)
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, isRead, createdAt])
  @@index([articleId])
  @@index([alertId])
  @@index([ruleId])
  @@index([feedId])
}

model GReaderPreference {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  streamId  String
  key       String
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, streamId, key])
  @@index([userId, streamId])
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

model Category {
  id        String   @id @default(cuid())
  name      String
  userId    String
  parentId  String?
  order     Int      @default(0)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent    Category? @relation("Subcategories", fields: [parentId], references: [id], onDelete: Cascade)
  children  Category[] @relation("Subcategories")
  feeds     Feed[]
  opmlUrl   String?
  updateFrequency Int?
  hideFromAllFeeds Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@unique([userId, name, parentId])
  @@index([userId])
  @@index([parentId])
}

model Feed {
  id              String   @id @default(cuid())
  url             String
  name            String
  icon            String?
  sourceType      String   @default("rss") // rss | HTML+XPath | XML+XPath | JSON+DotNotation | JSONFeed | HTML+XPath+JSON+DotNotation
  htmlUrl         String?
  description     String?
  priority        String   @default("main") // important | main | category | feed | hidden
  unicityCriteria String   @default("id")
  unicityCriteriaForced Boolean @default(false)
  scraperConfig   String?  // JSON for XPath / JSON DotNotation / xPathToJson settings
  httpOptions     String?  // JSON for Scout Studio cURL-like fetch options
  userId          String
  categoryId      String?
  order           Int      @default(0)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category        Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  articles        Article[]
  updateFrequency Int?
  retentionDays   Int?
  keepMinArticles Int?
  lastFetchedAt   DateTime?
  lastStatus       String?
  lastError        String?
  // F6: auto-mute after N consecutive failures (User.autoMuteFailingFeedsAfter).
  // Resets to 0 on any successful sync or a manual unmute.
  consecutiveFailureCount Int      @default(0)
  autoMuted               Boolean  @default(false)
  // Conditional GET (HTTP caching): sent as If-None-Match / If-Modified-Since on the next fetch.
  etag              String?
  lastModifiedHeader String?
  // Auth & fetch options
  authType          String?   // "basic"
  authUsername      String?
  authPassword      String?
  customUserAgent   String?
  fetchTimeoutSecs  Int?
  sslVerify         Boolean   @default(true)
  maxSizeKb         Int?
  // Full-text extraction
  fullTextSelector         String?
  fullTextRemoveSelectors  String?
  autoFetchFullText        Boolean   @default(false)
  fullTextConditions       String?
  fullTextMode             String    @default("off")  // "off" | "auto" | "selector" | "ai"
  defaultContentFormat     String    @default("html")  // "html" | "markdown" — preferred stored format for auto full-text
  // "Enable automatic full text for this feed?" suggestion (shown after a manual
  // fetch reveals the feed is truncated) was declined — don't ask again.
  fullTextAutoSuggestDismissed Boolean @default(false)
  filtersActionRead        String?
  hideFromAllFeeds         Boolean  @default(false)
  hideArticleImage         Boolean  @default(false)
  readerFontSizeOverride   String?  // null = inherit user.readerFontSize; else "small"|"medium"|"large"|"xl"
  readerWidthOverride      String?  // null = inherit user.readerWidth; else "normal"|"wide"|"full"
  openOriginalOverride     Boolean? // null = inherit user.openOriginalByDefault
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@unique([userId, url])
  @@index([userId])
  @@index([categoryId])
}

model Article {
  id          String   @id @default(cuid())
  feedId      String
  userId      String
  title       String
  link        String
  externalId   String?
  dedupeKey    String?
  contentHash  String?
  isDuplicate  Boolean  @default(false)
  duplicateOf  String?
  canonical    Article?  @relation("ArticleDuplicates", fields: [duplicateOf], references: [id], onDelete: SetNull)
  duplicates   Article[] @relation("ArticleDuplicates")
  content     String
  contentFormat String @default("html")  // "html" | "markdown" — the format `content` is stored in
  excerpt     String?
  author      String?
  publishedAt DateTime
  imageUrl    String?
  isRead      Boolean  @default(false)
  readAt      DateTime?
  isStarred   Boolean  @default(false)
  isReadLater Boolean  @default(false)
  readLaterSavedAt DateTime?
  isSpoiler     Boolean  @default(false)
  spoilerAt     DateTime?
  // Tracks which rule applied the spoiler flag so it can be cleared on rule deletion.
  spoilerRuleId String?
  notifications Notification[]
  feed        Feed     @relation(fields: [feedId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  labels      ArticleLabel[]
  aiSummary      String?
  aiSummarizedAt DateTime?
  aiTaggedAt     DateTime?                              // F8: set once auto-tagging has run, whether or not it produced any tags — avoids re-asking every sync
  digestedAt     DateTime?                              // set when article is sent in a digest
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@unique([userId, feedId, dedupeKey])
  @@index([userId, contentHash])
  @@index([userId, isRead, publishedAt])
  @@index([userId, isStarred, publishedAt])
  @@index([userId, isReadLater, readLaterSavedAt])
  @@index([userId, isSpoiler, publishedAt])
  @@index([userId, readAt])
  @@index([feedId, publishedAt])
  @@index([spoilerRuleId])
  @@index([userId, digestedAt])
}

model Label {
  id        String   @id @default(cuid())
  userId    String
  name      String
  color     String   @default("#3b82f6")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  articles  ArticleLabel[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@unique([userId, name])
  @@index([userId])
}

model ArticleLabel {
  articleId String
  labelId   String
  userId    String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  label     Label   @relation(fields: [labelId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  @@id([articleId, labelId])
  @@index([labelId])
  @@index([userId])
}

model SavedSearch {
  id         String    @id @default(cuid())
  userId     String
  name       String
  query      String
  order      Int       @default(0)
  shareToken String?   @unique
  sharedAt   DateTime?
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  @@unique([userId, name])
  @@index([userId, order])
}

model GlobalSettings {
  id                  String   @id @default("global")
  registrationsEnabled Boolean  @default(true)
  mailServiceEnabled   Boolean  @default(false)
  mailProvider        String   @default("smtp")
  // SMTP config
  smtpHost                 String?
  smtpPort                 Int?
  smtpUser                 String?
  smtpPassword             String?
  smtpFrom                 String?
  smtpSecure               String?
  smtpRejectUnauthorized   Boolean?
  // API mail providers (values encrypted at rest)
  resendApiKey        String?
  resendFromEmail     String?
  postmarkServerToken String?
  postmarkFromEmail   String?
  postmarkMessageStream String?
  mailgunApiKey       String?
  mailgunDomain       String?
  mailgunFromEmail    String?
  mailgunBaseUrl      String?
  sendgridApiKey      String?
  sendgridFromEmail   String?
  // Instance settings
  instanceName        String?
  instanceUrl         String?
  instanceIconDataUrl String?
  starterPacksJson    String?
  // Misc
  totpIssuer          String?
  backgroundSyncEnabled          Boolean @default(true)
  backgroundSyncIntervalMinutes  Int     @default(5)
  allowInternalFeedUrls          Boolean @default(false)
  // Optional browser-render sidecar (M7-T2): an admin-configured external
  // service that renders JS-heavy / client-only pages and returns HTML, used
  // as a fallback when in-process fetch+extract comes up empty. Hidden in the
  // UI until enabled. Token is encrypted at rest.
  renderSidecarEnabled           Boolean @default(false)
  renderSidecarUrl               String?
  renderSidecarToken             String?
  // Optional RSSHub connector (M5a): an admin-configured self-hosted RSSHub
  // instance, used for "Add from platform" (turning a YouTube channel,
  // subreddit, GitHub repo releases, etc. into a real feed via RSSHub's own
  // route conventions). Hidden in the UI until enabled. API key (RSSHub's
  // optional `?key=` access gate) is encrypted at rest.
  rsshubEnabled                  Boolean @default(false)
  rsshubBaseUrl                  String?
  rsshubApiKey                   String?
  // Optional changedetection.io connector (M5b): an admin-configured
  // self-hosted changedetection.io instance, used for "Monitor this page"
  // (any page, including JS-rendered ones since changedetection.io does its
  // own browser rendering) → creates a watch → its own per-watch RSS output
  // becomes a normal feed. Two DIFFERENT secrets, both encrypted at rest:
  // `changedetectionApiKey` (its REST API's `x-api-key`, used to create/
  // manage watches) and `changedetectionRssToken` (a separate "RSS access
  // token" changedetection.io requires as a `?token=` query param on the
  // per-watch RSS route — confirmed from its own source, the REST API key
  // does NOT work for this). Hidden in the UI until enabled.
  changedetectionEnabled         Boolean @default(false)
  changedetectionBaseUrl         String?
  changedetectionApiKey          String?
  changedetectionRssToken        String?
  // Onboarding
  onboardingCompleted Boolean @default(false)
  // Security
  require2FAForAdmins Boolean @default(false)
  disablePublicSharedSearches Boolean @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model ApiToken {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique
  feverKey   String?   @unique
  name       String    @default("Default")
  scope      String    @default("write")  // "read" | "write" | "admin"
  expiresAt  DateTime?
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  @@index([userId])
}

model LoginAttempt {
  id         String   @id @default(cuid())
  email      String
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  success    Boolean
  failReason String?  // "password" | "otp" | "inactive"
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([email, createdAt])
  @@index([createdAt])
}

model AdminAuditLog {
  id          String   @id @default(cuid())
  actorId     String
  actor       User     @relation("AuditActor", fields: [actorId], references: [id], onDelete: Cascade)
  action      String   // "user.role_change" | "user.suspend" | "user.unsuspend" | "user.delete" | "settings.update"
  targetId    String?
  targetEmail String?
  metadata    String?  // JSON
  createdAt   DateTime @default(now())

  @@index([actorId, createdAt])
  @@index([createdAt])
}

model SystemLog {
  id        String   @id @default(cuid())
  level     String   // "info" | "warn" | "error"
  category  String   // "mail" | "digest" | "sync"
  message   String
  metadata  String?  // JSON string
  createdAt DateTime @default(now())

  @@index([category, createdAt])
  @@index([createdAt])
}

model DiscoveryCatalogFeed {
  id          String   @id @default(cuid())
  url         String   @unique
  title       String
  description String?
  category    String   // "tech", "news", "gaming", "science", "business", "entertainment", "sports", "lifestyle", "dev", "design"
  language    String   @default("en") // "en", "de", "multi"
  iconUrl     String?
  popularity  Int      @default(0)
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([category, enabled, popularity])
  @@index([language, enabled])
}
