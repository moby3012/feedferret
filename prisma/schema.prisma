generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  twoFactorEnabled Boolean @default(false)
  twoFactorSecret  String?
  accounts      Account[]
  sessions      Session[]
  categories    Category[]
  feeds         Feed[]
  articles      Article[]
  labels        Label[]
  savedSearches SavedSearch[]
  autoReadRules AutoReadRule[]
  keywordAlerts KeywordAlert[]
  notifications Notification[]
  gReaderPreferences GReaderPreference[]
  pushSubscriptions PushSubscription[]
  webhooks          Webhook[]
  defaultUpdateFrequency Int @default(60)
  defaultRetentionDays Int @default(90)
  openOriginalByDefault Boolean @default(false)
  markReadAfterDelaySecs Int?      // null=instant(1s), 0=disabled
  defaultViewMode        String    @default("list")   // "list"|"grid"|"magazine"|"minimal"
  readerWidth            String    @default("normal")  // "normal"|"wide"|"full"
  defaultArticleSort     String    @default("newest")  // "newest"|"oldest"
  accentColor            String    @default("#5BA4CF")  // ice blue
  secondaryColor         String    @default("#F0963C")  // soft orange
  apiToken      String?   @unique
  isActive      Boolean   @default(true)
  digestEnabled           Boolean   @default(false)
  digestFrequency         String    @default("daily")   // "daily" | "weekly"
  digestDayOfWeek         Int?                          // 0=Sun … 6=Sat, weekly only
  digestHour              Int       @default(8)         // UTC hour 0-23
  digestScope             String    @default("unread")  // "unread" | "starred" | "readlater" | "all"
  digestFeedIds           String?                       // JSON array of feed IDs, null = all
  digestLastSentAt        DateTime?
  digestUnsubscribeToken  String?   @unique
  pushEnabled             Boolean   @default(false)
  pushFrequency           String    @default("immediate") // "off" | "immediate" | "hourly" | "daily"
  pushFeedIds             String?                       // JSON array of feed IDs, null = all
  pushPrivatePayloads     Boolean   @default(true)      // include article titles in push payloads
  pushLastSentAt          DateTime?
  hideDuplicates          Boolean   @default(true)
  markReadOnScroll        Boolean   @default(false)
  aiProvider              String?                       // "openai" | "anthropic" | "ollama" | "gemini" | "openrouter"
  aiApiKey                String?                       // encrypted at rest
  aiModel                 String?
  aiOllamaBaseUrl         String?
  aiAutoSummarize         Boolean   @default(false)
  aiSummaryLanguage       String    @default("same")   // "same" | BCP-47 tag e.g. "de"
  role          String    @default("USER")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PushSubscription {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint    String    @unique
  p256dh      String
  auth        String
  userAgent   String?
  platform    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lastUsedAt  DateTime?
  disabledAt  DateTime?
  @@index([userId, disabledAt])
}

model AutoReadRule {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String
  query           String
  action          String   // legacy single-action: "mark_read" | "star" | "label:<labelId>"
  // New multi-action list (JSON array of action ids). When present, takes
  // precedence over `action`. Example: ["mark_read","label:abc","notify_inapp"]
  actions         String?
  // Optional scope: "all" | "feed:<id>" | "category:<id>"
  scope           String?
  enabled         Boolean  @default(true)
  order           Int      @default(0)
  lastTriggeredAt DateTime?
  notifications   Notification[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  @@index([userId, enabled, order])
}

model KeywordAlert {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String
  query           String
  scope           String   @default("all") // "all" | "feed:<id>" | "category:<id>"
  actions         String   @default("[\"notify_inapp\"]") // JSON array
  enabled         Boolean  @default(true)
  lastTriggeredAt DateTime?
  notifications   Notification[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId, enabled])
  @@index([userId, scope])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // "keyword_alert" | "rule_match" | "feed_error" | "digest_sent"
  title     String
  body      String
  articleId String?
  article   Article? @relation(fields: [articleId], references: [id], onDelete: SetNull)
  feedId    String?
  alertId   String?
  alert     KeywordAlert? @relation(fields: [alertId], references: [id], onDelete: SetNull)
  ruleId    String?
  rule      AutoReadRule? @relation(fields: [ruleId], references: [id], onDelete: SetNull)
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, isRead, createdAt])
  @@index([articleId])
  @@index([alertId])
  @@index([ruleId])
}

model GReaderPreference {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  streamId  String
  key       String
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, streamId, key])
  @@index([userId, streamId])
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

model Category {
  id        String   @id @default(cuid())
  name      String
  userId    String
  parentId  String?
  order     Int      @default(0)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent    Category? @relation("Subcategories", fields: [parentId], references: [id], onDelete: Cascade)
  children  Category[] @relation("Subcategories")
  feeds     Feed[]
  opmlUrl   String?
  updateFrequency Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@unique([userId, name, parentId])
}

model Feed {
  id              String   @id @default(cuid())
  url             String
  name            String
  icon            String?
  sourceType      String   @default("rss") // rss | HTML+XPath | XML+XPath | JSON+DotNotation | JSONFeed | HTML+XPath+JSON+DotNotation
  htmlUrl         String?
  description     String?
  priority        String   @default("main") // important | main | category | feed | hidden
  unicityCriteria String   @default("id")
  unicityCriteriaForced Boolean @default(false)
  scraperConfig   String?  // JSON for XPath / JSON DotNotation / xPathToJson settings
  httpOptions     String?  // JSON for Scout Studio cURL-like fetch options
  userId          String
  categoryId      String?
  order           Int      @default(0)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category        Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  articles        Article[]
  updateFrequency Int?
  retentionDays   Int?
  keepMinArticles Int?
  lastFetchedAt   DateTime?
  lastStatus       String?
  lastError        String?
  // Auth & fetch options
  authType          String?   // "basic"
  authUsername      String?
  authPassword      String?
  customUserAgent   String?
  fetchTimeoutSecs  Int?
  sslVerify         Boolean   @default(true)
  maxSizeKb         Int?
  // Full-text extraction
  fullTextSelector         String?
  fullTextRemoveSelectors  String?
  autoFetchFullText        Boolean   @default(false)
  fullTextConditions       String?
  filtersActionRead        String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@unique([userId, url])
}

model Article {
  id          String   @id @default(cuid())
  feedId      String
  userId      String
  title       String
  link        String
  externalId   String?
  dedupeKey    String?
  contentHash  String?
  isDuplicate  Boolean  @default(false)
  duplicateOf  String?
  canonical    Article?  @relation("ArticleDuplicates", fields: [duplicateOf], references: [id], onDelete: SetNull)
  duplicates   Article[] @relation("ArticleDuplicates")
  content     String
  excerpt     String?
  author      String?
  publishedAt DateTime
  imageUrl    String?
  isRead      Boolean  @default(false)
  readAt      DateTime?
  isStarred   Boolean  @default(false)
  isReadLater Boolean  @default(false)
  readLaterSavedAt DateTime?
  notifications Notification[]
  feed        Feed     @relation(fields: [feedId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  labels      ArticleLabel[]
  aiSummary      String?
  aiSummarizedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@unique([userId, feedId, dedupeKey])
  @@index([userId, contentHash])
  @@index([userId, isRead, publishedAt])
  @@index([userId, isStarred, publishedAt])
  @@index([userId, isReadLater, readLaterSavedAt])
  @@index([userId, readAt])
  @@index([feedId, publishedAt])
}

model Label {
  id        String   @id @default(cuid())
  userId    String
  name      String
  color     String   @default("#3b82f6")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  articles  ArticleLabel[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@unique([userId, name])
  @@index([userId])
}

model ArticleLabel {
  articleId String
  labelId   String
  userId    String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  label     Label   @relation(fields: [labelId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  @@id([articleId, labelId])
  @@index([labelId])
  @@index([userId])
}

model SavedSearch {
  id         String    @id @default(cuid())
  userId     String
  name       String
  query      String
  order      Int       @default(0)
  shareToken String?   @unique
  sharedAt   DateTime?
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  @@unique([userId, name])
  @@index([userId, order])
}

model GlobalSettings {
  id                  String   @id @default("global")
  registrationsEnabled Boolean  @default(true)
  mailServiceEnabled   Boolean  @default(false)
  mailProvider        String   @default("smtp")
  // SMTP config
  smtpHost            String?
  smtpPort            Int?
  smtpUser            String?
  smtpPassword        String?
  smtpFrom            String?
  // API mail providers (values encrypted at rest)
  resendApiKey        String?
  resendFromEmail     String?
  postmarkServerToken String?
  postmarkFromEmail   String?
  postmarkMessageStream String?
  mailgunApiKey       String?
  mailgunDomain       String?
  mailgunFromEmail    String?
  mailgunBaseUrl      String?
  sendgridApiKey      String?
  sendgridFromEmail   String?
  // Instance settings
  instanceName        String?
  instanceUrl         String?
  instanceIconDataUrl String?
  starterPacksJson    String?
  // Misc
  totpIssuer          String?
  backgroundSyncEnabled          Boolean @default(true)
  backgroundSyncIntervalMinutes  Int     @default(5)
  allowInternalFeedUrls          Boolean @default(false)
  // Onboarding
  onboardingCompleted Boolean @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model Webhook {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  url         String
  secret      String
  enabled     Boolean  @default(true)
  events      String   @default("[\"new_article\"]")
  feedFilter  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deliveries  WebhookDelivery[]
  @@index([userId, enabled])
}

model WebhookDelivery {
  id          String   @id @default(cuid())
  webhookId   String
  webhook     Webhook  @relation(fields: [webhookId], references: [id], onDelete: Cascade)
  event       String
  payload     String
  status      String   @default("pending")
  statusCode  Int?
  error       String?
  attempts    Int      @default(0)
  nextRetryAt DateTime?
  deliveredAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([webhookId, createdAt])
  @@index([status, nextRetryAt])
}

model DiscoveryCatalogFeed {
  id          String   @id @default(cuid())
  url         String   @unique
  title       String
  description String?
  category    String   // "tech", "news", "gaming", "science", "business", "entertainment", "sports", "lifestyle", "dev", "design"
  language    String   @default("en") // "en", "de", "multi"
  iconUrl     String?
  popularity  Int      @default(0)
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([category, enabled, popularity])
  @@index([language, enabled])
}
